  "security_patterns": {
    "zero_trust": {
      "description": "Security model based on 'never trust, always verify'. No implicit trust based on network location. Every access request verified regardless of source.",
      "principles": [
        "Verify explicitly - always authenticate and authorize based on all available data points",
        "Use least privilege access - limit user access with just-in-time and just-enough-access",
        "Assume breach - minimize blast radius, encrypt all sessions, use analytics to get visibility"
      ],
      "components": {
        "identity": "Azure AD, Okta, Duo - MFA required for all access",
        "devices": "Device compliance check before access (MDM/EDR)",
        "applications": "Per-application authorization, no network-wide access",
        "data": "Data classification, DLP, encryption at rest and in transit",
        "infrastructure": "Micro-segmentation, just-in-time access",
        "network": "Encrypted sessions, network analytics, threat detection"
      },
      "implementation_sequence": [
        "1. Identity - Deploy MFA (Microsoft Authenticator, Duo)",
        "2. Endpoints - MDM enrollment (Intune, JAMF), EDR deployment",
        "3. Network - Micro-segmentation, east-west firewall",
        "4. Applications - Per-app conditional access policies",
        "5. Data - Classification and DLP policies",
        "6. Analytics - SIEM, UEBA, threat intelligence"
      ],
      "vendors": {
        "identity": ["Microsoft Entra ID", "Okta", "Ping Identity"],
        "network": ["Palo Alto Prisma Access", "Zscaler ZPA", "Cisco Umbrella"],
        "endpoint": ["CrowdStrike", "Microsoft Defender", "SentinelOne"]
      }
    },
    "defense_in_depth": {
      "description": "Multiple overlapping security layers so that if one layer fails, others remain in place.",
      "layers": [
        {
          "layer": 1,
          "name": "Perimeter Security",
          "technologies": ["NGFW", "IPS/IDS", "DDoS mitigation", "WAF"],
          "purpose": "Block external threats before they reach internal network"
        },
        {
          "layer": 2,
          "name": "Network Segmentation",
          "technologies": ["VLANs", "ACLs", "Firewall zones", "NAC"],
          "purpose": "Limit lateral movement once perimeter is breached"
        },
        {
          "layer": 3,
          "name": "Endpoint Protection",
          "technologies": ["EDR/XDR", "Host-based firewall", "Application whitelisting"],
          "purpose": "Protect individual devices from compromise"
        },
        {
          "layer": 4,
          "name": "Application Security",
          "technologies": ["WAF", "API gateway", "Code scanning", "DAST/SAST"],
          "purpose": "Protect applications from exploitation"
        },
        {
          "layer": 5,
          "name": "Data Protection",
          "technologies": ["Encryption at rest", "DLP", "Data classification", "Rights management"],
          "purpose": "Protect sensitive data even if other layers breached"
        },
        {
          "layer": 6,
          "name": "Identity and Access",
          "technologies": ["MFA", "PAM", "IAM", "Just-in-time access"],
          "purpose": "Ensure only authorized users access resources"
        },
        {
          "layer": 7,
          "name": "Monitoring and Response",
          "technologies": ["SIEM", "SOAR", "NDR", "Threat intelligence"],
          "purpose": "Detect, respond to, and recover from incidents"
        }
      ]
    },
    "micro_segmentation": {
      "description": "Fine-grained network segmentation extending beyond VLANs to workload-level isolation. Prevents lateral movement of threats.",
      "approaches": {
        "network_based": {
          "description": "VLAN/subnet-based with distributed firewall policies",
          "technologies": ["Cisco ACI", "VMware NSX-T", "Arista CloudVision"],
          "granularity": "Per workload/VM"
        },
        "host_based": {
          "description": "Software firewall on each host",
          "technologies": ["Windows Firewall", "iptables", "Illumio", "Guardicore"],
          "granularity": "Per process/application"
        },
        "overlay_based": {
          "description": "Microsegmentation through encrypted overlay",
          "technologies": ["Zscaler Private Access", "Palo Alto Prisma Access"],
          "granularity": "Per application"
        }
      },
      "use_cases": [
        "PCI-DSS cardholder data environment isolation",
        "Healthcare PHI data segmentation (HIPAA)",
        "Ransomware blast radius limitation",
        "Development/Production environment separation"
      ]
    },
    "dmz_architecture": {
      "description": "Demilitarized Zone - network segment between internet and internal network hosting public-facing services.",
      "zones": {
        "internet": "Untrusted - all traffic",
        "dmz": "Semi-trusted - web servers, email, DNS, VPN concentrators",
        "internal": "Trusted - internal applications, databases",
        "secure": "Highly restricted - PCI/HIPAA data, privileged management"
      },
      "firewall_policy": {
        "internet_to_dmz": "Allow specific services (80, 443, 25)",
        "dmz_to_internal": "Deny all by default, whitelist required",
        "internal_to_dmz": "Allow management traffic",
        "internal_to_internet": "Proxy/inspect all egress"
      }
    }
