  "topology_patterns": {
    "collapsed_core": {
      "user_range": "50-2000",
      "recommended_range": "100-1500",
      "layers": 2,
      "description": "Two-tier architecture combining core and distribution functions into a single layer. Access switches connect directly to core-distribution devices.",
      "pros": [
        "Lower cost - fewer devices required",
        "Simpler management and troubleshooting",
        "Reduced latency (fewer hops)",
        "Faster convergence with fewer routing adjacencies",
        "Lower power and rack space requirements",
        "Suitable for single-building deployments"
      ],
      "cons": [
        "Limited scalability beyond 2000 users",
        "Single failure domain for routing",
        "Less fault isolation between departments",
        "No distribution layer for policy enforcement",
        "Challenging to add redundancy at scale",
        "Not suitable for multi-building campuses"
      ],
      "use_cases": [
        "Branch offices (50-500 users)",
        "Small to medium businesses",
        "Single-floor or single-building deployments",
        "Remote sites in a hub-and-spoke WAN",
        "Retail locations",
        "Healthcare clinics (not hospitals)"
      ],
      "typical_hardware": {
        "core_switches": ["Cisco Catalyst 9300", "Cisco Catalyst 9500-24Q", "Arista 7050X"],
        "access_switches": ["Cisco Catalyst 9200", "Cisco Catalyst 9300-24P", "Arista 720XP"]
      },
      "routing_protocols": ["OSPF", "EIGRP"],
      "ha_options": ["HSRP", "VRRP", "VSS (Virtual Switching System)", "StackWise"],
      "bandwidth_guidelines": {
        "uplink_ratio": "1:20 (oversubscription)",
        "core_capacity": "10-40 Gbps",
        "access_uplinks": "1-10 Gbps"
      },
      "decision_criteria": {
        "choose_when": [
          "User count < 2000",
          "Single building or small campus",
          "Budget constrained",
          "Simple department structure",
          "Limited IT staff"
        ],
        "avoid_when": [
          "Multi-building campus",
          "High availability requirements (>99.99%)",
          "Strict compliance isolation needed",
          "Expecting growth beyond 3000 users"
        ]
      }
    },
    "three_tier": {
      "user_range": "2000-100000",
      "recommended_range": "5000-50000",
      "layers": 3,
      "description": "Three distinct layers: Core (high-speed backbone), Distribution (policy enforcement, routing), Access (user connectivity). Industry standard for enterprise campus networks.",
      "pros": [
        "Excellent scalability to 100,000+ users",
        "Strong fault isolation between layers",
        "Policy enforcement at distribution layer",
        "Simplified troubleshooting per layer",
        "Supports hierarchical routing design",
        "Industry-proven for large enterprises",
        "Modular - add distribution blocks without core changes"
      ],
      "cons": [
        "Higher cost than collapsed core",
        "More complex configuration and management",
        "Additional network hops (latency)",
        "Requires skilled networking staff",
        "More physical devices and cabling"
      ],
      "use_cases": [
        "Enterprise campus networks",
        "University campuses",
        "Multi-building corporate headquarters",
        "Hospital networks",
        "Government agency networks",
        "Large retail chains (central DC)"
      ],
      "typical_hardware": {
        "core_switches": ["Cisco Catalyst 9500-48Y4C", "Cisco Nexus 9364C", "Arista 7500R3"],
        "distribution_switches": ["Cisco Catalyst 9400", "Cisco Catalyst 9500-32C", "Arista 7280R3"],
        "access_switches": ["Cisco Catalyst 9200", "Cisco Catalyst 9300", "Arista 720XP"]
      },
      "routing_protocols": ["OSPF", "BGP (for multi-site)"],
      "ha_options": ["VSS", "StackWise Virtual", "HSRP/VRRP at distribution", "BFD"],
      "bandwidth_guidelines": {
        "core_to_distribution": "40-100 Gbps",
        "distribution_to_access": "10-40 Gbps",
        "access_uplinks": "1-10 Gbps",
        "oversubscription_ratio": "1:4 at distribution, 1:20 at access"
      },
      "decision_criteria": {
        "choose_when": [
          "User count > 2000",
          "Multi-building or multi-floor campus",
          "Need strong fault isolation",
          "Compliance requirements (PCI-DSS, HIPAA)",
          "Multiple departments with different security policies",
          "Plans for significant growth"
        ],
        "avoid_when": [
          "Pure data center environment (use spine-leaf)",
          "Very small deployments (< 500 users)",
          "Extremely cost-constrained"
        ]
      }
    },
    "spine_leaf": {
      "user_range": "Data center workloads",
      "server_range": "50-100000 servers",
      "layers": 2,
      "description": "Data center fabric architecture. Every leaf switch connects to every spine switch. No leaf-to-leaf connections. Provides uniform latency and horizontal scalability for east-west traffic.",
      "pros": [
        "Predictable, uniform latency (2 hops max)",
        "Horizontal scalability - add spine or leaf without redesign",
        "Excellent for east-west (server-to-server) traffic",
        "No spanning tree - ECMP for load balancing",
        "High bandwidth with multiple ECMP paths",
        "Supports VXLAN/EVPN for overlay networks"
      ],
      "cons": [
        "Not designed for campus user connectivity",
        "More cable density than three-tier",
        "Higher upfront cost for full mesh cabling",
        "Adds complexity with VXLAN/EVPN overlay",
        "Spine switches are high-density and expensive"
      ],
      "use_cases": [
        "Enterprise data centers",
        "Cloud provider data centers",
        "Hyperscale computing environments",
        "High-performance computing (HPC) clusters",
        "Containerized application environments (Kubernetes)",
        "Financial trading platforms (low latency)"
      ],
      "typical_hardware": {
        "spine_switches": ["Cisco Nexus 9336C-FX2", "Arista 7800R3", "Juniper QFX10002"],
        "leaf_switches": ["Cisco Nexus 93180YC-FX", "Arista 7050CX3", "Juniper QFX5120"]
      },
      "routing_protocols": ["BGP EVPN", "OSPF (underlay)", "iBGP/eBGP (overlay)"],
      "overlay_technologies": ["VXLAN", "EVPN", "MPLS"],
      "bandwidth_guidelines": {
        "leaf_to_spine_uplinks": "25-400 Gbps per link",
        "server_facing_ports": "10-100 Gbps",
        "spine_capacity": "400 Gbps - 12.8 Tbps"
      },
      "design_rules": {
        "max_leaf_count": "Limited by spine port count",
        "spine_count": "Typically 2-4 for HA",
        "oversubscription": "3:1 typical, 1:1 for HPC"
      },
      "decision_criteria": {
        "choose_when": [
          "Pure data center environment",
          "High east-west traffic requirements",
          "Need uniform low latency",
          "Cloud-native workloads",
          "Container/microservices architecture"
        ],
        "avoid_when": [
          "Campus user network",
          "WAN edge design",
          "Small environments (< 10 servers)"
        ]
      }
    },
    "hub_and_spoke": {
      "user_range": "Varies by hub size",
      "site_range": "2-500 sites",
      "description": "Centralized topology where remote sites (spokes) connect back to a central site (hub). All spoke-to-spoke traffic routes through hub.",
      "pros": [
        "Simple configuration",
        "Centralized security policy enforcement",
        "Cost-effective for many small sites",
        "Easy to add new spoke sites"
      ],
      "cons": [
        "Hub is single point of failure",
        "Spoke-to-spoke latency (double hop)",
        "Hub bandwidth can become bottleneck",
        "Poor for real-time applications between spokes"
      ],
      "use_cases": [
        "Retail chain networks",
        "Bank branch networks",
        "Small remote office connectivity",
        "Legacy enterprise WAN"
      ]
    },
    "full_mesh": {
      "site_range": "2-6 sites",
      "description": "Every site connects directly to every other site.",
      "pros": [
        "Optimal routing between any two sites",
        "Excellent resilience",
        "Lowest latency between sites"
      ],
      "cons": [
        "Connection count grows exponentially (n*(n-1)/2)",
        "Very expensive beyond 6 sites",
        "Complex management"
      ],
      "use_cases": [
        "Small number of critical data centers",
        "Financial trading hub interconnects",
        "Carrier-grade network interconnects"
      ]
    },
    "partial_mesh": {
      "site_range": "4-50 sites",
      "description": "Key sites fully connected, less critical sites using hub-and-spoke.",
      "pros": [
        "Balance of cost and performance",
        "Critical paths fully redundant",
        "Manageable complexity"
      ],
      "cons": [
        "More complex design decisions",
        "Some sites have suboptimal routing"
      ],
      "use_cases": [
        "Regional enterprise networks",
        "Mid-size service provider networks"
      ]
    }
  },
  "wan_patterns": {
    "mpls": {
      "description": "Multiprotocol Label Switching - carrier-managed Layer 2.5 service providing private WAN connectivity with traffic engineering capabilities.",
      "type": "Private WAN",
      "pros": [
        "Guaranteed SLAs (latency, jitter, packet loss)",
        "Quality of Service (QoS) with traffic classes",
        "Private network - no internet exposure",
        "Provider-managed infrastructure",
        "Sub-50ms failover with Fast Reroute",
        "MPLS TE for traffic engineering"
      ],
      "cons": [
        "High cost - typically 5-10x internet pricing",
        "Long provisioning lead times (30-90 days)",
        "Limited geographic availability",
        "Locked to single carrier",
        "Not cloud-optimized"
      ],
      "use_cases": [
        "Financial services (trading, banking)",
        "Healthcare critical applications",
        "Voice/video conferencing primary transport",
        "Legacy application connectivity"
      ],
      "typical_bandwidth": "10 Mbps - 10 Gbps",
      "latency_guarantee": "< 50ms intra-country",
      "availability_sla": "99.9-99.99%"
    },
    "sd_wan": {
      "description": "Software-Defined WAN - overlay technology abstracting transport and applying intelligent traffic steering across multiple underlying connections.",
      "type": "Overlay on multiple transports",
      "pros": [
        "Transport agnostic (MPLS, internet, LTE, 5G)",
        "Centralized management via controller",
        "Application-aware routing (SaaS optimization)",
        "Zero-touch provisioning",
        "Lower cost vs pure MPLS",
        "Built-in security (IPSec overlay)",
        "Cloud on-ramp for SaaS/IaaS"
      ],
      "cons": [
        "Complexity in design and operation",
        "Internet transport quality variable",
        "Additional overlay overhead",
        "Requires new skill sets",
        "Vendor lock-in potential"
      ],
      "use_cases": [
        "Multi-site enterprises (10+ sites)",
        "Direct internet access for SaaS (Office 365, Salesforce)",
        "Cloud connectivity optimization",
        "Cost reduction from MPLS migration",
        "Branch office modernization"
      ],
      "vendors": ["Cisco Viptela/Catalyst SD-WAN", "VMware VeloCloud", "Silver Peak (HPE Aruba)", "Fortinet SD-WAN", "Palo Alto Prisma SD-WAN"],
      "transport_types": ["MPLS", "Internet (broadband)", "4G/LTE", "5G", "Satellite (VSAT)"],
      "traffic_steering": {
        "sla_aware": "Steer based on measured latency/loss/jitter",
        "application_aware": "Recognize apps by DPI and apply policies",
        "cloud_optimized": "Direct breakout for trusted SaaS"
      }
    },
