  "ha_patterns": {
    "active_active": {
      "description": "Both nodes processing traffic simultaneously. Load distributed across nodes. Failover is seamless.",
      "pros": [
        "Maximum resource utilization",
        "Seamless failover (no traffic interruption)",
        "Linear capacity scaling",
        "Better performance under normal operations"
      ],
      "cons": [
        "Complex configuration (state synchronization)",
        "More expensive (both nodes fully licensed)",
        "State synchronization latency",
        "Harder to troubleshoot"
      ],
      "use_cases": [
        "Load balancers (F5, Citrix)",
        "Firewalls with session synchronization",
        "BGP route reflectors",
        "Web application servers"
      ],
      "technologies": ["ECMP routing", "Anycast", "F5 Active-Active", "Palo Alto Active-Active"],
      "rto_rpo": {
        "rto": "< 1 second (sub-second failover)",
        "rpo": "0 (no data loss)"
      }
    },
    "active_standby": {
      "description": "Primary node handles all traffic; standby node monitors and takes over on failure.",
      "pros": [
        "Simpler configuration",
        "Lower risk of split-brain",
        "Easier troubleshooting",
        "Standard approach for firewalls"
      ],
      "cons": [
        "Standby resources idle under normal conditions",
        "Failover time (5-30 seconds typical)",
        "Session loss on failover without sync"
      ],
      "use_cases": [
        "Firewalls (Cisco ASA, Palo Alto, Fortinet)",
        "Routers (HSRP, VRRP, GLBP)",
        "Database servers",
        "Critical infrastructure with simple traffic patterns"
      ],
      "failover_times": {
        "hsrp_default": "10-30 seconds",
        "hsrp_optimized": "1-3 seconds (sub-second with BFD)",
        "vrrp_default": "Master Down Interval (3x advertisement interval)",
        "bgp_bfd": "< 1 second"
      }
    },
    "n_plus_1": {
      "description": "N active nodes with 1 spare available to replace any failed node.",
      "capacity_loss_on_failure": "1/N of capacity (briefly until failover)",
      "use_cases": [
        "Server clusters",
        "Network device pools",
        "Power systems"
      ],
      "examples": [
        "3 active switches + 1 spare",
        "5 servers + 1 spare in cluster",
        "RAID-5 disk arrays"
      ]
    },
    "n_plus_2": {
      "description": "N active nodes with 2 spares. Tolerates 2 simultaneous failures.",
      "use_cases": [
        "Mission-critical systems",
        "Financial trading systems",
        "Hospital life safety systems"
      ],
      "cost": "Higher than N+1, justified for <99.999% uptime requirements"
    },
    "geo_redundancy": {
      "description": "Active-active or active-standby data centers in different geographic locations.",
      "patterns": {
        "active_active_dc": {
          "description": "Both DCs serve traffic simultaneously",
          "technologies": ["GSLB", "Anycast", "Active-Active WAN"],
          "rto": "< 1 second",
          "distance_requirement": "> 100 miles for disaster recovery"
        },
        "active_standby_dc": {
          "description": "Primary DC serves all traffic, DR DC activates on disaster",
          "technologies": ["DNS failover", "BGP anycast", "Warm standby"],
          "rto": "5-30 minutes",
          "distance_requirement": "> 300 miles for major disaster scenarios"
        }
      },
      "rpo_rto_requirements": {
        "tier1_mission_critical": {"rpo": "0", "rto": "< 1 minute"},
        "tier2_business_critical": {"rpo": "< 1 hour", "rto": "< 4 hours"},
        "tier3_important": {"rpo": "< 24 hours", "rto": "< 8 hours"},
        "tier4_non_critical": {"rpo": "< 7 days", "rto": "< 72 hours"}
      }
